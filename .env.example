# Copy to .env for local runs. All vars are prefixed AEGIS_ (see src/aegis/config.py).

# JWT signing — CHANGE THIS in any non-local environment.
AEGIS_JWT_SECRET=dev-secret-change-me-please-32-bytes-min
AEGIS_JWT_ALG=HS256
AEGIS_JWT_AUDIENCE=aegis

# Upstream services the gateway federates over.
AEGIS_UPSTREAM_URL=http://upstreams:9000

# Redis cache.
AEGIS_REDIS_URL=redis://redis:6379/0
AEGIS_CACHE_TTL=30

# Logging.
AEGIS_LOG_LEVEL=INFO
